              "operation": "equal",
              "value2": "dsa"
            }
          ]
        }
      },
      "id": "if-dsa",
      "name": "Is DSA Agent?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        800,
        700
      ]
    },
    {
      "parameters": {
        "workflowId": "VwKsTBRvIqo5vleR"
      },
      "id": "execute-dsa",
      "name": "Execute DSA Agent",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.1,
      "position": [
        1000,
        800
      ]
    },
    {
      "parameters": {
        "chatId": "={{ $('Determine Route').first().json.chat_id }}",
        "text": "={{ ($json.output || $json.text || 'Done!').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/\\\\*\\\\*(.*?)\\\\*\\\\*/g, '<b>$1</b>').replace(/\\\\[(.*?)\\\\]\\\\((.*?)\\\\)/g, '<a href=\\\"$2\\\">$1</a>').replace(/`(.*?)`/g, '<code>$1</code>') }}",
        "additionalFields": {
          "parseMode": "HTML"
        }
      },
      "id": "send-reply",
      "name": "Send Reply",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        1200,
