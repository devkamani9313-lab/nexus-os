      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [200, 300]
    },
    {
      "parameters": {
        "workflowId": "select-news-workflow-id-after-import",
        "options": {
          "waitForCompletion": true
        }
      },
