          "values": [
            {
              "name": "text",
              "value": "Provide a comprehensive summary of the top news stories in India for today and yesterday. Focus on major events, politics, markets, and social trends. Cover at least 5-7 major stories."
            },
            {
              "name": "chat_id",
              "value": "7731571949"
            }
          ]
        },
        "options": {}
      },
      "id": "set-india-input",
